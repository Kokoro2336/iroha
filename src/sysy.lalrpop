use crate::base::Type;
use crate::frontend::ast::*;
use crate::frontend::parse::*;
use std::ffi::CString;

grammar(parser: &mut Parser);

match {
  r"\s*" => {},
  r"//[^\n\r]*[\n\r]*" => {},
  r"/\*([^*]|\*+[^/*])*\*+/" => {},
  _
}

pub CompUnit: NodeId = {
  <enter_scope: EnterScope> <global_objs: (GlobalObj)*> <exit_scope: ExitScope> => {
    let mut statements = vec![];
    for obj in global_objs {
      match parser.ast.get_node_type(obj) {
        NodeType::DeclAggr => {
          let decls = parser.ast.remove(obj);
          for decl in decls {
            if matches!(parser.ast[decl], Node::VarArray { .. }) {
              let values = if let Node::VarArray { init_values, .. } = &mut parser.ast[decl] {
                init_values.take()
              } else {
                None
              };

              if let Some(values) = values {
                if values.is_empty() {
                  if let Node::VarArray { init_values, .. } = &mut parser.ast[decl] {
                    *init_values = None;
                  }
                } else {
                  let mut folded_values = Vec::with_capacity(values.len());
                  for init_val in values {
                    let node = std::mem::take(&mut parser.ast[init_val]);
                    let folded = parser.fold(node);
                    folded_values.push(parser.ast.alloc(folded));
                  }
                  if let Node::VarArray { init_values, .. } = &mut parser.ast[decl] {
                    *init_values = Some(folded_values);
                  }
                }
              }
            } else if matches!(parser.ast[decl], Node::VarDecl { .. }) {
              let (typ, mutable, init_value) = if let Node::VarDecl { typ, mutable, init_value, .. } = &parser.ast[decl] {
                (typ.clone(), *mutable, *init_value)
              } else {
                unreachable!()
              };

              if mutable {
                if init_value.is_none() {
                  let default_init = match typ {
                    Type::Int | Type::Float | Type::Pointer { .. } => {
                      Some(parser.ast.alloc(Node::Literal(Literal::Int(0))))
                    }
                    _ => None,
                  };
                  if let Node::VarDecl { init_value, .. } = &mut parser.ast[decl] {
                    *init_value = default_init;
                  }
                } else if let Some(value) = init_value {
                  let node = std::mem::take(&mut parser.ast[value]);
                  let folded = parser.fold(node);
                  let folded_id = parser.ast.alloc(folded);
                  if let Node::VarDecl { init_value, .. } = &mut parser.ast[decl] {
                    *init_value = Some(folded_id);
                  }
                }
              }
            }
            statements.push(decl);
          }
        }
        _ => statements.push(obj),
      }
    }

    parser.ast.alloc(Node::Block { statements })
  }
};

EnterScope: () = {
  () => {
    parser.syms.enter_scope();
  },
};

ExitScope: () = {
  () => {
    parser.syms.exit_scope();
  },
};

GlobalObj: NodeId = {
  <func_def: FuncDef> => func_def,
  <global_decl: Decl> => global_decl,
};

FuncDef: NodeId = {
  <b_type: BType> <ident: Ident> "(" <func_fparams: FuncFParams> ")" <block: Block> => {
    let param_types = func_fparams.iter().map(|(_, t)| t.clone()).collect();
    parser.ast.alloc(Node::FnDecl {
      name: ident,
      params: func_fparams,
      typ: Type::Function {
        return_type: Box::new(b_type.clone()),
        param_types,
      },
      body: block,
    })
  },
  <b_type: BType> <ident: Ident> "(" ")" <block: Block> => {
    parser.ast.alloc(Node::FnDecl {
      name: ident,
      params: vec![],
      body: block,
      typ: Type::Function {
        return_type: Box::new(b_type.clone()),
        param_types: vec![],
      },
    })
  },
  "void" <ident: Ident> "(" <func_fparams: FuncFParams> ")" <block: Block> => {
    let param_types = func_fparams.iter().map(|(_, t)| t.clone()).collect();
    parser.ast.alloc(Node::FnDecl {
      name: ident,
      params: func_fparams,
      body: block,
      typ: Type::Function {
        return_type: Box::new(Type::Void),
        param_types,
      },
    })
  },
  "void" <ident: Ident> "(" ")" <block: Block> => {
    parser.ast.alloc(Node::FnDecl {
      name: ident,
      params: vec![],
      body: block,
      typ: Type::Function {
        return_type: Box::new(Type::Void),
        param_types: vec![],
      },
    })
  },
};

FuncFParams: Vec<(String, Type)> = {
  <first_param: FuncFParam> <other_params: ("," FuncFParam)*> => {
    let mut param_list = vec![first_param];
    for (_, other_param) in other_params {
      param_list.push(other_param);
    }
    param_list
  }
};

FuncFParam: (String, Type) = {
  <param_type: BType> <ident: Ident> => (ident, param_type),
  <param_type: BType> <ident: Ident> <first_const_exp: ("[" "]")> <other_const_exps: ("[" ConstExp "]")*> => {
    let arr_type = Type::Pointer {
      base: if other_const_exps.is_empty() {
        Box::new(param_type)
      } else {
        Box::new(Type::Array {
          base: Box::new(param_type),
          dims: other_const_exps.into_iter().map(|(_, exp, _)| {
            let node = std::mem::take(&mut parser.ast[exp]);
            match parser.fold(node) {
              Node::Literal(Literal::Int(i)) => i as u32,
              _ => panic!("Array dimension must be an integer literal"),
            }
          }).collect(),
        })
      },
    };
    (ident, arr_type)
  }
};

FuncType: Type = {
  "void" => Type::Void,
  <b_type: BType> => b_type,
};

BType: Type = {
  "int" => Type::Int,
  "float" => Type::Float,
};

Block: NodeId = "{" <enter_scope: EnterScope> <block_items: (BlockItem)*> <exit_scope: ExitScope> "}" => {
  let mut statements = vec![];
  for item in block_items {
    match parser.ast.get_node_type(item) {
      NodeType::DeclAggr => {
        let decls = parser.ast.remove(item);
        for decl in decls {
          statements.push(decl);
        }
      }
      _ => statements.push(item),
    }
  }
  parser.ast.alloc(Node::Block { statements })
};

BlockItem: NodeId = {
  <stmt: Stmt> => stmt,
  <decl: Decl> => decl,
};

Stmt: NodeId = {
  <open_stmt: OpenStmt> => open_stmt,
  <close_stmt: CloseStmt> => close_stmt,
};

CloseStmt: NodeId = {
  <simple_stmt: SimpleStmt> => simple_stmt,
  "if" "(" <condition: Exp> ")" <then_stmt: CloseStmt> "else" <else_stmt: CloseStmt> => parser.ast.alloc(Node::If {
      condition,
      then_block: then_stmt,
      else_block: Some(else_stmt),
  }),
  "while" "(" <condition: Exp> ")" <body_stmt: CloseStmt> => parser.ast.alloc(Node::While {
      condition,
      body: body_stmt,
  }),
};

OpenStmt: NodeId = {
  "if" "(" <condition: Exp> ")" <then_stmt: CloseStmt> "else" <else_stmt: OpenStmt> => parser.ast.alloc(Node::If {
      condition,
      then_block: then_stmt,
      else_block: Some(else_stmt),
  }),
  "if" "(" <condition: Exp> ")" <then_stmt: Stmt> => parser.ast.alloc(Node::If {
      condition,
      then_block: then_stmt,
      else_block: None,
  }),
  "while" "(" <condition: Exp> ")" <body_stmt: OpenStmt> => parser.ast.alloc(Node::While {
      condition,
      body: body_stmt,
  }),
};

SimpleStmt: NodeId = {
  <l_val: LVal> "=" <exp: Exp> ";" => parser.ast.alloc(Node::Assign { lhs: l_val, rhs: exp }),
  <block: Block> => block,
  "return" <exp: Exp> ";" => parser.ast.alloc(Node::Return(Some(exp))),
  "return" ";" => parser.ast.alloc(Node::Return(None)),
  "break" ";" => parser.ast.alloc(Node::Break),
  "continue" ";" => parser.ast.alloc(Node::Continue),
  <exp: Exp> ";" => exp,
  ";" => parser.ast.alloc(Node::Empty),
};

LVal: NodeId = {
  <ident: Ident> <exps: ("[" Exp "]")*> => {
    if exps.is_empty() {
      parser.ast.alloc(Node::VarAccess {
        name: ident,
        typ: Type::Void,
      })
    } else {
      parser.ast.alloc(Node::ArrayAccess {
        name: ident,
        indices: exps.into_iter().map(|(_, exp, _)| exp).collect(),
        typ: Type::Void,
      })
    }
  },
};

Decl: NodeId = {
  <const_decl: ConstDecl> => const_decl,
  <var_decl: VarDecl> => var_decl,
};

ConstDecl: NodeId = {
  "const" <b_type: BType> <const_def: ConstDef> <other_const_defs: ("," ConstDef)*> ";" => {
    let mut const_defs = vec![const_def];
    for (_, def) in other_const_defs {
      const_defs.push(def);
    }

    let raw_decl = parser.ast.alloc(Node::RawDecl {
      typ: b_type,
      mutable: false,
      raw_decls: const_defs,
    });

    let decls = parser.canonicalize(raw_decl);

    parser.ast.alloc(Node::DeclAggr {
      decls,
    })
  }
};

ConstDef: RawDef = {
  <ident: Ident> <const_exps: ("[" ConstExp "]")*> "=" <const_init_val: ConstInitVal> => {
    RawDef {
      ident,
      const_exps: const_exps.into_iter().map(|(_, exp, _)| exp).collect(),
      init_val: Some(const_init_val),
    }
  }
};

ConstInitVal: NodeId = {
  <const_exp: ConstExp> => const_exp,
  "{" "}" => parser.ast.alloc(Node::ArrayInitVal { init_vals: vec![] }),
  "{" <first_init_val: ConstInitVal> <other_init_vals: ("," ConstInitVal)*> "}" => {
    let mut init_vals = vec![first_init_val];
    for (_, val) in other_init_vals {
      init_vals.push(val);
    }
    parser.ast.alloc(Node::ArrayInitVal { init_vals })
  }
};

ConstExp: NodeId = {
  <exp: Exp> => exp,
};

VarDecl: NodeId = {
  <b_type: BType> <var_def: VarDef> <other_var_defs: ("," VarDef)*> ";" => {
    let mut var_defs = vec![var_def];
    for (_, def) in other_var_defs {
      var_defs.push(def);
    }

    let raw_decl = parser.ast.alloc(Node::RawDecl {
      typ: b_type,
      mutable: true,
      raw_decls: var_defs,
    });

    let decls = parser.canonicalize(raw_decl);

    parser.ast.alloc(Node::DeclAggr {
      decls,
    })
  }
};

VarDef: RawDef = {
  <ident: Ident> <const_exps: ("[" ConstExp "]")*> "=" <init_val: InitVal> => RawDef {
    ident,
    const_exps: const_exps.into_iter().map(|(_, exp, _)| exp).collect(),
    init_val: Some(init_val),
  },
  <ident: Ident> <const_exps: ("[" ConstExp "]")*> => RawDef {
    ident,
    const_exps: const_exps.into_iter().map(|(_, exp, _)| exp).collect(),
    init_val: None,
  },
};

InitVal: NodeId = {
  <exp: Exp> => exp,
  "{" "}" => parser.ast.alloc(Node::ArrayInitVal { init_vals: vec![] }),
  "{" <first_init_val: InitVal> <other_init_vals: ("," InitVal)*> "}" => {
    let mut init_vals = vec![first_init_val];
    for (_, val) in other_init_vals {
      init_vals.push(val);
    }
    parser.ast.alloc(Node::ArrayInitVal { init_vals })
  }
};

Exp: NodeId = {
  <lor_exp: LOrExp> => lor_exp,
};

LOrExp: NodeId = {
  <lor_exp: LOrExp> <lor_op: LOrOp> <land_exp: LAndExp> => parser.ast.alloc(Node::BinaryOp {
      typ: Type::Void,
      lhs: lor_exp,
      op: lor_op,
      rhs: land_exp,
  }),
  <land_exp: LAndExp> => land_exp,
};

LAndExp: NodeId = {
  <land_exp: LAndExp> <land_op: LAndOp> <eq_exp: EqExp> => parser.ast.alloc(Node::BinaryOp {
      typ: Type::Void,
      lhs: land_exp,
      op: land_op,
      rhs: eq_exp,
  }),
  <eq_exp: EqExp> => eq_exp,
};

EqExp: NodeId = {
  <eq_exp: EqExp> <eq_op: EqOp> <rel_exp: RelExp> => parser.ast.alloc(Node::BinaryOp {
      typ: Type::Void,
      lhs: eq_exp,
      op: eq_op,
      rhs: rel_exp,
  }),
  <rel_exp: RelExp> => rel_exp,
};

RelExp: NodeId = {
  <rel_exp: RelExp> <rel_op: RelOp> <add_exp: AddExp> => parser.ast.alloc(Node::BinaryOp {
      typ: Type::Void,
      lhs: rel_exp,
      op: rel_op,
      rhs: add_exp,
  }),
  <add_exp: AddExp> => add_exp,
};

UnaryExp: NodeId = {
  <unary_op: UnaryOp> <unary_exp: UnaryExp> => parser.ast.alloc(Node::UnaryOp {
      typ: Type::Void,
      op: unary_op,
      operand: unary_exp,
  }),
  <ident: Ident> "(" <arg: Exp> <other_args: ("," Exp)*> ")" => parser.ast.alloc(Node::Call {
      typ: Type::Void,
      func_name: ident,
      args: {
        let mut args_vec = vec![arg];
        for (_, other_arg) in other_args {
          args_vec.push(other_arg);
        }
        args_vec
      },
  }),
  <ident: Ident> "(" ")" => parser.ast.alloc(Node::Call {
      typ: Type::Void,
      func_name: ident,
      args: vec![],
  }),
  <primary_exp: PrimaryExp> => primary_exp,
};

AddExp: NodeId = {
  <add_exp: AddExp> <add_op: AddOp> <mul_exp: MulExp> => parser.ast.alloc(Node::BinaryOp {
      typ: Type::Void,
      lhs: add_exp,
      op: add_op,
      rhs: mul_exp,
  }),
  <mul_exp: MulExp> => mul_exp,
};

MulExp: NodeId = {
  <mul_exp: MulExp> <mul_op: MulOp> <unary_exp: UnaryExp> => parser.ast.alloc(Node::BinaryOp {
      typ: Type::Void,
      lhs: mul_exp,
      op: mul_op,
      rhs: unary_exp,
  }),
  <unary_exp: UnaryExp> => unary_exp,
};

PrimaryExp: NodeId = {
  "(" <exp: Exp> ")" => exp,
  <l_val: LVal> => l_val,
  <num: Number> => num,
};

LOrOp: Op = {
  "||" => Op::Or,
};

LAndOp: Op = {
  "&&" => Op::And,
};

EqOp: Op = {
  "==" => Op::Eq,
  "!=" => Op::Ne,
};

RelOp: Op = {
  "<" => Op::Lt,
  "<=" => Op::Le,
  ">" => Op::Gt,
  ">=" => Op::Ge,
};

UnaryOp: Op = {
  r"\+" => Op::Plus,
  r"-" => Op::Minus,
  r"!" => Op::Not,
};

MulOp: Op = {
  r"\*" => Op::Mul,
  r"/" => Op::Div,
  r"%" => Op::Mod,
};

AddOp: Op = {
  r"\+" => Op::Add,
  r"-" => Op::Sub,
};

Number: NodeId = {
  <int: IntConst> => parser.ast.alloc(Node::Literal(Literal::Int(int))),
  <float: FloatConst> => parser.ast.alloc(Node::Literal(Literal::Float(float))),
  <fmt_string: FormattedString> => parser.ast.alloc(Node::Literal(Literal::String(fmt_string))),
};

Ident: String = <s: r"[_a-zA-Z][_a-zA-Z0-9]*"> => {
  s.to_string()
};

IntConst: i32 = {
  r"[1-9][0-9]*" => i32::from_str_radix(<>, 10).unwrap(),
  r"0[0-7]*" => i32::from_str_radix(<>, 8).unwrap(),
  r"0[xX][0-9a-fA-F]+" => i32::from_str_radix(&<>[2..], 16).unwrap(),
};

FloatConst: f32 = {
  r"[+-]?(?:(?:[0-9]*\.[0-9]+|[0-9]+\.)(?:[eE][+-]?[0-9]+)?|[0-9]+[eE][+-]?[0-9]+)" => str::parse::<f32>(&<>).unwrap(),
  r"0[xX](?:[0-9a-fA-F]*\.[0-9a-fA-F]+|[0-9a-fA-F]+\.?)[pP][+-]?[0-9]+" => {
    let c_str = CString::new(<>).unwrap();
    unsafe { libc::strtof(c_str.as_ptr(), std::ptr::null_mut()) }
  },
};

FormattedString: String = {
  r"%([-+#0]*)([\d]+|\*)?(?:\.([\d]+|\*))?(hh|ll|[hlLzjt])?([dcf])" => <>.to_string(),
};
